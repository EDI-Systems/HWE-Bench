{
  "ComponentID": "CP2102N",
  "ComponentType": "USB-to-UART Bridge Controller",
  "Description": "The CP2102N is a highly-integrated USB-to-UART bridge controller that provides a complete solution for adding USB connectivity to applications with a UART interface. It incorporates a USB 2.0 full-speed function controller, transceiver, oscillator, and UART, requiring no external USB components, firmware development, or crystal. It is configured via a GUI tool and supports virtual COM port drivers, enabling rapid conversion of legacy RS-232 systems to USB.",
  "KeyParameters": {
    "USB Specification": "USB 2.0 Full-Speed (12 Mbps)",
    "UART Baud Rate": "300 baud to 3 Mbaud",
    "Operating Voltage (VDD)": "3.0 V to 3.6 V or 3.0 V to 5.25 V (depending on configuration)",
    "Regulated Output Voltage (VREGIN/VDD mode)": "3.3 V",
    "Operating Current": "9.5 mA (typical)",
    "UART FIFO Buffers": "512-byte receive, 512-byte transmit",
    "Integrated Features": "USB transceiver, clock, voltage regulator, power-on reset",
    "Package Options": "QFN28, QFN24, QFN20",
    "Operating Temperature": "-40°C to +85°C"
  },
