{
  "ComponentID": "ISO1042",
  "ComponentType": "Galvanically-Isolated CAN (Controller Area Network) Transceiver",
  "Description": "The ISO1042-Q1 is an automotive-qualified, isolated CAN transceiver that provides electrical isolation between the CAN protocol controller and the physical bus. It supports both classic CAN (up to 1 Mbps) and CAN FD (Flexible Data Rate, up to 5 Mbps) standards. Its primary function is to transmit data from the controller (via TXD) onto the differential CAN bus (CANH, CANL) and receive data from the bus to the controller (via RXD), while protecting the local system from high bus voltages, noise, and ground potential differences through its integrated isolation barrier and robust protection features like ±70-V DC bus fault tolerance.",
  "KeyParameters": {
    "**Isolation Withstand Voltage**": "5000 VRMS for 1 minute (UL 1577)",
    "**Maximum Data Rate**": "5 Mbps (CAN FD)",
    "**Common-Mode Voltage Range (Bus)**": "±30 V",
    "**DC Bus Fault Protection**": "±70 V",
    "**Logic-Side Supply Voltage (VCC1)**": "1.71 V to 5.5 V",
    "**Bus-Side Supply Voltage (VCC2)**": "4.5 V to 5.5 V",
    "**Common-Mode Transient Immunity (CMTI)**": "100 kV/µs",
    "**Loop Delay (Propagation)**": "152 ns (typical)",
    "**ESD Protection (Bus Pins, HBM)**": "±16 kV",
    "**Ambient Temperature Range**": "–40°C to +125°C"
  },
