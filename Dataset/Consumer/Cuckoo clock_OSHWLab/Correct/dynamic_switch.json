{
  "Motor Load Switch & Inrush Buffer": [
    {
      "net_id": "net_power",
      "Connections": [
        { "ComponentID": "Arduino", "PinName": "TOP_4", "FunctionName": "Power" },
        { "ComponentID": "IRLM", "PinName": "3", "FunctionName": "Source" }
      ]
    },
    {
      "net_id": "net_gnd",
      "Connections": [
        { "ComponentID": "Arduino", "PinName": "TOP_5", "FunctionName": "Ground" },
        { "ComponentID": "ES9251II", "PinName": "3", "FunctionName": "Ground" }
      ]
    },
    {
      "net_id": "net_ctrl",
      "Connections": [
        { "ComponentID": "Arduino", "PinName": "LEFT_10", "FunctionName": "Digital I/O" },
        { "ComponentID": "IRLM", "PinName": "1", "FunctionName": "Gate" }
      ]
    },
    {
      "net_id": "net_motor",
      "Connections": [
        { "ComponentID": "IRLM", "PinName": "2", "FunctionName": "Drain" },
        { "ComponentID": "ES9251II", "PinName": "2", "FunctionName": "Power Supply" }
      ]
    }
  ]
}