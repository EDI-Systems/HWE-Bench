{
  "MCU_Function_Groups": {
    "ATmega328p": {
      "SPI_ICSP_Shared_Bus": [
        { "PinName": "PB2", "FunctionName": "SPI_CS" },
        { "PinName": "PB3", "FunctionName": "SPI_MOSI" },
        { "PinName": "PB4", "FunctionName": "SPI_MISO" },
        { "PinName": "PB5", "FunctionName": "SPI_SCK" },
        { "PinName": "PC6", "FunctionName": "ICSP_RESET" }
      ],
      "I2C_Communication_Bus": [
        { "PinName": "PC4", "FunctionName": "I2C_SDA" },
        { "PinName": "PC5", "FunctionName": "I2C_SCL" }
      ],
      "Motor_Control_Channel": [
        { "PinName": "PD3", "FunctionName": "MOTOR_PWM" }
      ],
      "System_Power_Control": [
        { "PinName": "VCC", "FunctionName": "Power_5V" },
        { "PinName": "AVCC", "FunctionName": "Analog_Power" },
        { "PinName": "GND", "FunctionName": "Ground" },
        { "PinName": "AREF", "FunctionName": "Analog_Ref" }
      ]
    }
  },
  "Component_Interfaces": {
    "MICRO": {
      "SPI_Interface": [
        { "PinName": "CD/DAT3", "FunctionName": "SPI_CS" },
        { "PinName": "CMD", "FunctionName": "SPI_MOSI" },
        { "PinName": "DAT0", "FunctionName": "SPI_MISO" },
        { "PinName": "CLK", "FunctionName": "SPI_SCK" }
      ]
    },
    "OLED": {
      "I2C_Interface": [
        { "PinName": "SDA", "FunctionName": "I2C_SDA" },
        { "PinName": "SCK", "FunctionName": "I2C_SCL" }
      ]
    },
    "ICSP": {
      "Programming_Port": [
        { "PinName": "MOSI", "FunctionName": "SPI_MOSI" },
        { "PinName": "MISO", "FunctionName": "SPI_MISO" },
        { "PinName": "SCK", "FunctionName": "SPI_SCK" },
        { "PinName": "RESET", "FunctionName": "ICSP_RESET" }
      ]
    },
    "PC817": {
      "Opto_Input": [
        { "PinName": "A", "FunctionName": "MOTOR_PWM" }
      ]
    }
  },
  "Routing_Rules": [
    {
      "RuleName": "Shared_SPI_ICSP_Link",
      "Type": "Bus_Pairing",
      "MCU": "ATmega328p",
      "Target_Group_Pattern": "SPI_ICSP_Shared_Bus",
      "Slaves": [
        { "ComponentID": "MICRO", "Interface": "SPI_Interface" },
        { "ComponentID": "ICSP", "Interface": "Programming_Port" }
      ]
    },
    {
      "RuleName": "Display_OLED_I2C_Link",
      "Type": "Bus_Pairing",
      "MCU": "ATmega328p",
      "Target_Group_Pattern": "I2C_Communication_.*",
      "Slaves": [
        { "ComponentID": "OLED", "Interface": "I2C_Interface" }
      ]
    },
    {
      "RuleName": "Tape_Motor_Opto_Isolation",
      "Type": "Resource_Allocation",
      "MCU": "ATmega328p",
      "Target_Group": "Motor_Control_Channel",
      "Slaves": [
        { "ComponentID": "PC817", "Interface": "Opto_Input" }
      ]
    },
    {
      "RuleName": "Power_5V_to_LDO_Input",
      "Type": "Direct_Link",
      "Nodes": [
        { "ComponentID": "ATmega328p", "PinName": "VCC" },
        { "ComponentID": "AMS1117", "PinName": "VIN" }
      ]
    },
    {
      "RuleName": "Power_3V3_to_SDCard",
      "Type": "Direct_Link",
      "Nodes": [
        { "ComponentID": "AMS1117", "PinName": "VOUT" },
        { "ComponentID": "MICRO", "PinName": "VDD" }
      ]
    }
  ]
}