        { "PinName": "LED_NPWR", "FunctionName": "Power Status Driver" },
        { "PinName": "PWR_BUTTON", "FunctionName": "Soft Power Key" },
        { "PinName": "NRPIBOOT", "FunctionName": "Boot Mode Selector" }
      ]
    }
  },
  "Component_Interfaces": {
    "bq25895": {
      "I2C_Bus": [
        { "PinName": "SCL", "FunctionName": "Serial Clock" },
        { "PinName": "SDA", "FunctionName": "Serial Data" }
      ],
      "Power_Main": [
        { "PinName": "VBUS", "FunctionName": "Input from USB" },
        { "PinName": "SYS", "FunctionName": "System Output" },
        { "PinName": "VBAT", "FunctionName": "Battery Terminal" }
      ]
    },
    "LSM6DSV16XTR": {
      "I2C_Standard": [
        { "PinName": "SCL", "FunctionName": "Clock" },
        { "PinName": "SDA", "FunctionName": "Data" }
      ]
    },
    "TF-123": {
      "SD_Card_Slot": [
        { "PinName": "CLK", "FunctionName": "Serial Clock" },
        { "PinName": "CMD", "FunctionName": "Command" },
        { "PinName": "DAT0", "FunctionName": "Data 0" },
        { "PinName": "DAT1", "FunctionName": "Data 1" },
        { "PinName": "DAT2", "FunctionName": "Data 2" },
        { "PinName": "CD/DAT3", "FunctionName": "Chip Select / Data 3" }
      ]
    },
    "RT9742": {
      "Gated_Switch": [
        { "PinName": "EN", "FunctionName": "Enable Logic" },
        { "PinName": "IN", "FunctionName": "Power In" },
        { "PinName": "OUT", "FunctionName": "Power Out" }
      ]
    },
    "74LVC1G07": {
      "Buffer_Gate": [
        { "PinName": "A", "FunctionName": "Logic Input" },
        { "PinName": "Y", "FunctionName": "Open-Drain Output" }
      ]
    },
    "USB": {
      "TypeC_Input": [
        { "PinName": "VBUS", "FunctionName": "Main Power" }
      ]
    }
