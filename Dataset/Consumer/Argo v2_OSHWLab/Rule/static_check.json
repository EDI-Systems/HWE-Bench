      "MicroSD_SDIO_Bus": [
        { "PinName": "SD_CLK", "FunctionName": "Clock Output" },
        { "PinName": "SD_CMD", "FunctionName": "Command Line" },
        { "PinName": "SD_DAT0", "FunctionName": "Data Bit 0" },
        { "PinName": "SD_DAT1", "FunctionName": "Data Bit 1" },
        { "PinName": "SD_DAT2", "FunctionName": "Data Bit 2" },
        { "PinName": "SD_DAT3", "FunctionName": "Data Bit 3" },
        { "PinName": "SD_PWR_ON", "FunctionName": "Slot Power Enable" }
      ],
      "Charger_I2C0_Management": [
        { "PinName": "SDA0", "FunctionName": "I2C0 Data / BQ25895" },
        { "PinName": "SCL0", "FunctionName": "I2C0 Clock / BQ25895" },
        { "PinName": "CHG_INT", "FunctionName": "Charger Interrupt Input" }
      ],
      "Sensor_I2C_IMU": [
        { "PinName": "GPIO2", "FunctionName": "I2C SDA / Sensor Hub" },
        { "PinName": "GPIO3", "FunctionName": "I2C SCL / Sensor Hub" }
