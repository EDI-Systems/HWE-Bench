  "Routing_Rules": [
    {
      "RuleName": "Check_Charger_Control_Loop",
      "Type": "Bus_Pairing",
      "MCU": "SBC_Core",
      "Target_Group_Pattern": "Charger_I2C0_.*",
      "Slaves": [ { "ComponentID": "bq25895", "Interface": "I2C_Bus" } ]
    },
    {
      "RuleName": "Check_IMU_Sensor_I2C",
      "Type": "Bus_Pairing",
      "MCU": "SBC_Core",
      "Target_Group_Pattern": "Sensor_I2C_.*",
      "Slaves": [ { "ComponentID": "LSM6DSV16XTR", "Interface": "I2C_Standard" } ]
    },
    {
      "RuleName": "Check_SDIO_Storage_Integrity",
      "Type": "Bus_Pairing",
      "MCU": "SBC_Core",
      "Target_Group_Pattern": "MicroSD_SDIO_.*",
      "Slaves": [ { "ComponentID": "TF-123", "Interface": "SD_Card_Slot" } ]
    },
    {
      "RuleName": "Check_USB_Power_Injection",
      "Type": "Direct_Link",
      "Nodes": [
        { "ComponentID": "USB", "PinName": "VBUS" },
        { "ComponentID": "bq25895", "PinName": "VBUS" }
      ]
    },
    {
      "RuleName": "Check_VSYS_Power_Chain",
      "Type": "Direct_Link",
      "Nodes": [
        { "ComponentID": "bq25895", "PinName": "SYS" },
        { "ComponentID": "TPS61022", "PinName": "VIN" }
      ]
    },
    {
      "RuleName": "Check_VREF_to_MCU_Supply",
      "Type": "Direct_Link",
      "Nodes": [
        { "ComponentID": "TLV704", "PinName": "VOUT" },
        { "ComponentID": "SBC_Core", "PinName": "VDD_3V3" }
      ]
    }
  ]
}