{
  "ComponentID": "bq25895",
  "ComponentType": "I2C-Controlled Single-Cell Li-Ion/Li-Polymer Battery Charger and Power Path Manager with Boost Converter",
  "Description": "The bq25895 is a highly integrated switch-mode battery charge management and system power path management IC designed for single-cell Li-Ion/Li-Polymer batteries. It features a 5-A buck charger optimized for high-voltage inputs (up to 14 V) and includes a boost converter capable of delivering up to 3.1 A from the battery to the system. The device supports Narrow-VDC (NVDC) power path management, allowing the system to operate instantly with or without a battery. It integrates all necessary MOSFETs, current sensing, and control logic, and is configurable via I2C for parameters like input current limit, charge voltage/current, and boost output voltage. Key features include USB input detection (SDP, CDP, DCP), Input Current Optimizer (ICO), battery temperature monitoring, and thermal regulation.",
  "KeyParameters": {
    "**Charge Topology**": "Switch-mode buck converter",
    "**Max Charge Current**": "5 A",
    "**Input Voltage Range**": "3.9 V to 14 V",
    "**Battery Charge Voltage Regulation Accuracy**": "±0.5%",
    "**Boost Converter Output Voltage Range**": "4.5 V to 5.5 V (adjustable)",
    "**Max Boost Output Current**": "3.1 A",
    "**Switching Frequency (Charge)**": "1.5 MHz (fixed)",
    "**Switching Frequency (Boost)**": "500 kHz to 1.5 MHz (selectable)",
    "**Battery Discharge MOSFET Rds(on)**": "11 mΩ",
    "**Quiescent Current (Low Battery Leakage)**": "12 µA"
  },
