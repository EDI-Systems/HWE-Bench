{
  "ComponentID": "SG3525A",
  "ComponentType": "Pulse Width Modulator (PWM) Controller IC",
  "Description": "The SG3525A series are integrated circuits designed for controlling switching power supplies. They generate a variable-duty-cycle pulse train (PWM) to regulate output voltage/current. Key features include an internal 5.1V trimmed reference, an error amplifier with a common-mode range that includes the reference, a wide-frequency oscillator (sync-capable), adjustable dead time control, internal soft-start, undervoltage lockout with hysteresis, a pulse-terminating latch to prevent multiple pulses per cycle, and dual totem-pole output drivers capable of sourcing and sinking current.",
  "KeyParameters": {
    "Supply Voltage (Operating)": "8 V to 35 V",
    "Reference Output Voltage": "5.1 V (trimmed to ±1% for SG2525A, ±2% for SG3525A)",
    "Oscillator Frequency Range": "100 Hz to 500 kHz",
    "Output Driver Current (Source/Sink)": "> 200 mA (Typical), 500 mA (Absolute Max)",
    "Undervoltage Lockout Hysteresis": "~500 mV",
    "Dead Time Control": "Adjustable via external resistor",
    "Soft-Start": "Controlled via external capacitor",
    "Total Power Dissipation (Max)": "1000 mW",
    "Operating Temperature Range (SG3525A)": "0°C to 70°C"
  },
