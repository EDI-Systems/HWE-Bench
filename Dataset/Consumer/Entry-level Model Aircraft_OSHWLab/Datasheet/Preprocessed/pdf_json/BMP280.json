{
  "ComponentID": "BMP280",
  "ComponentType": "Digital Barometric Pressure Sensor (MEMS)",
  "Description": "The BMP280 is an absolute barometric pressure and temperature sensor from Bosch Sensortec, designed for mobile and battery-powered applications. It utilizes piezo-resistive MEMS technology for high accuracy, linearity, and long-term stability. The sensor provides compensated digital pressure and temperature data via I²C or SPI interfaces, featuring ultra-low power consumption, multiple operating modes (sleep, forced, normal), and an integrated IIR filter for noise reduction. Its primary applications include altitude tracking, indoor/outdoor navigation, weather monitoring, and vertical velocity indication.",
  "KeyParameters": {
    "Pressure Measurement Range": "300 to 1100 hPa",
    "Relative Accuracy (Pressure)": "±0.12 hPa (700–900 hPa @ 25°C)",
    "Absolute Accuracy (Pressure)": "Typ. ±1 hPa (950–1050 hPa, 0 to +40°C)",
    "Temperature Coefficient Offset (TCO)": "1.5 Pa/K (equiv. to 12.6 cm/K)",
    "Current Consumption": "2.7 µA @ 1 Hz sampling rate (typical)",
    "Supply Voltage (VDD)": "Minimum 1.71 V",
    "Digital Interfaces": "I²C (up to 3.4 MHz), SPI (3- and 4-wire, up to 10 MHz)",
    "Operating Temperature Range": "-40 to +85 °C",
    "Package": "8-pin LGA, 2.0 x 2.5 mm², 0.95 mm height"
