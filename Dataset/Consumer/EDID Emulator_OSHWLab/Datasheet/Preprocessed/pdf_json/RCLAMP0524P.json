{
  "ComponentID": "RCLAMP0524P",
  "ComponentType": "TVS Diode Array (ESD Protection Device)",
  "Description": "The RCLAMP0524P is an ultra-low capacitance, 5V-rated TVS diode array designed for high-speed data line protection. It provides robust, multi-channel ESD, EFT, and surge protection for sensitive interfaces by clamping transient overvololtages to a safe level. Its primary function is to shunt harmful electrical transients from IEC standards to ground, thereby protecting downstream integrated circuits in applications like HDMI, DVI, PCIe, and SATA.",
  "KeyParameters": {
    "Reverse Working Voltage (VRWM)": "5 V (Max)",
    "Breakdown Voltage (VBR)": "6.8 to 9.5 V (IT = 1mA)",
    "Clamping Voltage (VC)": "17 V (Max, IPP = 4.5A, 8/20µs)",
    "Peak Pulse Current (Ipp)": "4.5 A (8/20µs)",
    "ESD Protection Level (IEC 61000-4-2)": "±25 kV (Air), ±20 kV (Contact)",
    "Junction Capacitance (CJ)": "0.35 pF (Typ, I/O to I/O), 0.6 to 0.8 pF (I/O to GND)",
    "Reverse Leakage Current (IR)": "0.08 µA (Max, VRWM = 5V)",
    "Operating Temperature Range (TJ)": "-55 to +125 °C",
    "Package": "DFN2510-10 (2.5mm × 1.0mm × 0.5mm)"
  },
