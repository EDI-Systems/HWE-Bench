{
  "ComponentID": "ESP32-WROVER",
  "ComponentType": "Wi-Fi + Bluetooth + Bluetooth LE System-on-Chip (SoC) Module with Integrated Flash and PSRAM",
  "Description": "The ESP32-WROVER-E and ESP32-WROVER-IE are powerful, general-purpose Wi-Fi + Bluetooth + Bluetooth LE MCU modules based on the ESP32-D0WD-V3 chip. They are designed for a wide range of applications from low-power sensor networks to demanding tasks like audio processing. The modules integrate 4 MB of SPI flash and 8 MB of SPI PSRAM. The primary difference is the antenna solution: the WROVER-E uses a PCB onboard antenna, while the WROVER-IE uses a connector for an external antenna. The core features a dual-core Xtensa LX6 microprocessor with clock speeds from 80 MHz to 240 MHz, rich peripherals (ADC, DAC, touch sensors, SPI, I2C, I2S, UART, etc.), and ultra-low-power management with a deep sleep current under 5 µA.",
  "KeyParameters": {
    "Core": "Dual-core Xtensa LX6 microprocessor",
    "CPU Clock Speed": "80 MHz to 240 MHz (adjustable)",
    "Integrated Flash Memory": "4 MB (SPI)",
    "Integrated PSRAM": "8 MB (SPI)",
    "Operating Voltage": "3.0 V to 3.6 V",
    "Wi-Fi Protocol": "802.11 b/g/n (up to 150 Mbps)",
    "Bluetooth": "Bluetooth 4.2 BR/EDR and BLE compliant",
    "Operating Temperature Range": "-40°C to 85°C",
    "Supply Current": "Minimum 500 mA",
    "Sleep Current": "< 5 µA",
    "Wi-Fi RF Frequency": "2412 ~ 2484 MHz"
  },
