{
  "ComponentID": "ESP32",
  "ComponentType": "Wi-Fi + Bluetooth + BLE System-on-Chip (SoC) Module",
  "Description": "The ESP32-WROOM-32D and ESP32-WROOM-32U are highly integrated, generic-purpose modules built around the ESP32-D0WD dual-core microcontroller. They provide comprehensive wireless connectivity including Wi-Fi (802.11 b/g/n), Bluetooth Classic, and Bluetooth Low Energy (BLE). The modules are designed for a wide range of applications from low-power sensor networks to demanding tasks like audio processing, featuring rich peripherals, configurable CPU clock speeds, and advanced power management with deep sleep currents below 5 µA. The primary difference between the D and U variants is the antenna interface: the 32D has an onboard PCB antenna, while the 32U integrates a U.FL connector for an external antenna.",
  "KeyParameters": {
    "Core": "Dual-core Xtensa® 32-bit LX6 microprocessor (ESP32-D0WD)",
    "CPU Clock Frequency": "Adjustable from 80 MHz to 240 MHz",
    "Operating Voltage": "3.0 V to 3.6 V",
    "Wi-Fi Output Power": "Up to 20 dBm",
    "Wi-Fi Data Rate": "Up to 150 Mbps",
    "Bluetooth": "Bluetooth v4.2 BR/EDR and BLE specification",
    "Integrated Flash Memory": "32 Mbit (4 MB) SPI flash",
    "Operating Temperature Range": "–40 °C to +85 °C",
    "Sleep Current": "< 5 µA",
    "Dimensions (WxLxH)": "32D: 18.00 mm × 25.50 mm × 3.10 mm; 32U: 18.00 mm × 19.20 mm × 3.20 mm"
  },
