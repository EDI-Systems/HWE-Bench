{
  "ComponentID": "ESP32-WROVER",
  "ComponentType": "Wi-Fi + Bluetooth + Bluetooth LE System-on-Chip (SoC) Module",
  "Description": "The ESP32-WROVER-E and ESP32-WROVER-IE are highly-integrated, general-purpose Wi-Fi + Bluetooth + Bluetooth LE MCU modules. They are built around the ESP32-D0WD-V3 dual-core Xtensa® LX6 microprocessor, featuring integrated 4 MB SPI flash and 8 MB SPI PSRAM. The modules support IEEE 802.11 b/g/n Wi-Fi (up to 150 Mbps) and Bluetooth v4.2 BR/EDR & BLE standards. Designed for low-power applications, they include a rich set of peripherals (GPIO, ADC, DAC, SPI, I2C, I2S, UART, PWM, touch sensors, etc.) and are capable of handling demanding tasks like audio processing. The primary difference between the -E and -IE variants is the antenna: the -E uses a PCB antenna, while the -IE uses a connector for an external antenna.",
  "KeyParameters": {
    "Core": "Dual-core Xtensa® LX6 microprocessor",
    "CPU Clock Speed": "80 MHz to 240 MHz (adjustable)",
    "Integrated Flash Memory": "4 MB SPI Flash",
    "Integrated PSRAM": "8 MB SPI PSRAM",
    "Operating Voltage": "3.0 V to 3.6 V",
    "Wi-Fi Protocol": "802.11 b/g/n (802.11n up to 150 Mbps)",
    "Bluetooth Protocol": "Bluetooth v4.2 BR/EDR and BLE",
    "Operating Temperature Range": "-40°C to 85°C",
    "Sleep Current": "< 5 µA",
    "RF Output Power (Typical)": "Up to 20 dBm",
    "Wi-Fi Receiver Sensitivity": "-97 dBm (typical for Bluetooth BLE)"
  },
