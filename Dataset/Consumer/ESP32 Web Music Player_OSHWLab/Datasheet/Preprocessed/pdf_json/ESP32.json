{
  "ComponentID": "ESP32",
  "ComponentType": "Wi-Fi + Bluetooth + Bluetooth LE System-on-Chip (SoC) Module with Integrated Flash and PSRAM",
  "Description": "The ESP32-WROVER-E and ESP32-WROVER-IE are powerful, general-purpose Wi-Fi + Bluetooth + Bluetooth LE MCU modules based on the ESP32-D0WD-V3 chip. They integrate a dual-core Xtensa LX6 microprocessor, 4 MB of SPI flash, and 8 MB of SPI PSRAM. The modules support IEEE 802.11 b/g/n Wi-Fi up to 150 Mbps and Bluetooth v4.2 BR/EDR & BLE. They are designed for a wide range of applications from low-power sensor networks to demanding tasks like audio processing. The key difference is the antenna type: the WROVER-E uses a PCB antenna, while the WROVER-IE uses a connector for an external antenna.",
  "KeyParameters": {
    "Core": "Dual-core Xtensa LX6 microprocessor",
    "CPU Clock Speed": "80 MHz to 240 MHz (adjustable)",
    "Integrated Flash Memory": "4 MB SPI Flash",
    "Integrated PSRAM": "8 MB SPI PSRAM",
    "Operating Voltage": "3.0 V to 3.6 V",
    "Wi-Fi Protocol": "802.11 b/g/n (802.11n with data rate up to 150 Mbps)",
    "Bluetooth Protocol": "Bluetooth v4.2 BR/EDR and Bluetooth LE",
    "Operating Temperature Range": "-40°C to 85°C",
    "Sleep Current": "< 5 µA",
    "RF Output Power": "Up to 20 dBm",
    "Wi-Fi Receiver Sensitivity": "-97 dBm (NZIF)"
  },
