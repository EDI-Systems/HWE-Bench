{
  "ComponentID": "MPU-9250",
  "ComponentType": "9-Axis Motion Tracking Unit (IMU + Magnetometer + DMP)",
  "Description": "The MPU-9250 is a multi-chip module (MCM) that integrates a 3-axis MEMS gyroscope, a 3-axis MEMS accelerometer, and a 3-axis magnetometer (AK8963) along with a Digital Motion Processor (DMP). It provides complete 9-axis sensor fusion output. The device digitizes all sensor outputs with 16-bit ADCs, includes programmable filters and full-scale ranges, and communicates via I2C or SPI interfaces. It is designed for motion tracking in portable and wearable electronics.",
  "KeyParameters": {
    "Gyroscope Full-Scale Range": "Programmable ±250, ±500, ±1000, ±2000 °/sec",
    "Accelerometer Full-Scale Range": "Programmable ±2g, ±4g, ±8g, ±16g",
    "Magnetometer Full-Scale Range": "±4800 µT",
    "Operating Voltage (VDD)": "2.4V to 3.6V",
    "Digital I/O Voltage (VDDIO)": "1.71V to VDD",
    "Communication Interfaces": "I2C (up to 400 kHz), SPI (1 MHz standard, up to 20 MHz for sensor/read interrupt)",
    "Package": "3x3x1 mm QFN",
    "Gyroscope Operating Current": "3.2 mA",
    "Sleep Mode Current": "8 µA"
  },
