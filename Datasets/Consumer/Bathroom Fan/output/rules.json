{
  "MCU_Function_Groups": {
    "Atmega": {
      "I2C_0": [
        { "PinName": "2-SDA", "FunctionName": "I2C Data" },
        { "PinName": "3-SCL", "FunctionName": "I2C Clock" }
      ],
      "SPI_0": [
        { "PinName": "16-MOSI", "FunctionName": "SPI MOSI / DA" },
        { "PinName": "15-SCLK", "FunctionName": "SPI Clock / CL" },
        { "PinName": "14-MISO", "FunctionName": "SPI MISO" }
      ],
      "GPIO_Pool": [
        { "PinName": "4", "FunctionName": "GPIO / Analog Input " },
        { "PinName": "5", "FunctionName": "GPIO / Analog Input" },
        { "PinName": "7", "FunctionName": "GPIO / Analog Input" },
        { "PinName": "6-A7", "FunctionName": "GPIO / Analog Input" },
        { "PinName": "8-A8", "FunctionName": "GPIO / Analog Input" },
        { "PinName": "9-A9", "FunctionName": "GPIO / Analog Input" },
        { "PinName": "10-A10", "FunctionName": "GPIO / Analog Input" },
        { "PinName": "A0", "FunctionName": "GPIO / Analog Input" },
        { "PinName": "A1", "FunctionName": "GPIO / Analog Input" },
        { "PinName": "A2", "FunctionName": "GPIO / Analog Input" },
        { "PinName": "A3", "FunctionName": "GPIO / Analog Input" }
      ]
    }
  },
  "Component_Interfaces": {
    "A1250": { 
      "I2C_Target": [
        { "PinName": "SDA", "FunctionName": "I2C Data" },
        { "PinName": "SCL", "FunctionName": "I2C Clock" }
      ] 
    },
    "AHT10": {
       "I2C_Target": [
        { "PinName": "SDA", "FunctionName": "Serial Data" },
        { "PinName": "SCL", "FunctionName": "Serial Clock" }
      ]
     },
    "OLED": {
      "SPI_Interface": [
        { "PinName": "SDA", "FunctionName": "Serial Data" },
        { "PinName": "SCL", "FunctionName": "Serial Clock" }
      ],
      "Control_Interface": [
        { "PinName": "CS", "FunctionName": "Chip Select" },
        { "PinName": "DC", "FunctionName": "Data/Command Select" },
       { "PinName": "RES", "FunctionName": "Reset" }
      ]
    },
    "S8050": { 
      "Base_Drive":[
        { "PinName": "Base", "FunctionName": "Control Input" }
      ] 
    },
    "IRL": {
       "Power_Switch": [
        { "PinName": "S", "FunctionName": "Source" },
        { "PinName": "G", "FunctionName": "Gate" }
      ] 
    },
    "2N7002": {
      "Logic_Switch": [
        { "PinName": "Drain (D)", "FunctionName": "Output / Power" }
      ],
      "Logic_Switch2": [
        { "PinName": "Gate (G)", "FunctionName": "Control Input" }
      ]
    },
    "1N4007": {
       "Feedback_Diode": [
        { "PinName": "Anode", "FunctionName": "Anode Terminal" }
      ] 
    }
  },
  "Routing_Rules": [
    {
      "RuleName": "Relay_to_Fan_Output",
      "Type": "Direct_Link", 
      "Nodes": [
        { "ComponentID": "G3MB", "PinName": "AC1" },
        { "ComponentID": "HB611-6.35", "PinName": "AC_FAN_O" }
      ]
    },
    {
      "RuleName": "LED_Drive_Cathode",
      "Type": "Direct_Link",
      "Nodes": [
        { "ComponentID": "LEDR", "PinName": "Cathode" },
        { "ComponentID": "G3MB", "PinName": "-" }
      ]
    },
    {
      "RuleName": "LED_Drive_Anode",
      "Type": "Direct_Link",
      "Nodes": [
        { "ComponentID": "LEDR", "PinName": "Anode" },
        { "ComponentID": "G3MB", "PinName": "+" }
      ]
    },
    {
      "RuleName": "Switcher_NMOS_to_PMOS",
      "Type": "Direct_Link",
      "Nodes": [
        { "ComponentID": "2N7002", "PinName": "Drain (D)" },
        { "ComponentID": "IRL", "PinName": "G" }
      ]
    },
    {
      "RuleName": "Switcher_Diode_to_MOSFET",
      "Type": "Direct_Link",
      "Nodes": [
        { "ComponentID": "1N4007", "PinName": "Cathode" },
        { "ComponentID": "IRL", "PinName": "G" }
      ]
    },
    {
      "RuleName": "I2C_Bus_Shared_Group",
      "Type": "Bus_Pairing",
      "MCU": "Atmega",
      "Target_Group_Pattern": "I2C_.*",
      "Slaves": [
        { "ComponentID": "A1250", "Interface": "I2C_Target" },
        { "ComponentID": "AHT10", "Interface": "I2C_Target" }
      ]
    },
    {
      "RuleName": "OLED_SPI_Communication",
      "Type": "Bus_Pairing",
      "MCU": "Atmega",
      "Target_Group_Pattern": "SPI_.*",
      "Slaves": [{ "ComponentID": "OLED", "Interface": "SPI_Interface" }]
    },
    {
      "RuleName": "OLED_Control_Signals",
      "Type": "Resource_Allocation",
      "MCU": "Atmega",
      "Target_Group": "GPIO_Pool",
      "Slaves": [{ "ComponentID": "OLED", "Interface": "Control_Interface" }]
    },
    {
      "RuleName": "Switcher_Logic_Control",
      "Type": "Resource_Allocation",
      "MCU": "Atmega",
      "Target_Group": "GPIO_Pool",
      "Slaves": [{ "ComponentID": "2N7002", "Interface": "Logic_Switch2" }]
    },
    {
      "RuleName": "Relay_Control_Logic",
      "Type": "Resource_Allocation",
      "MCU": "Atmega",
      "Target_Group": "GPIO_Pool",
      "Slaves": [{ "ComponentID": "S8050", "Interface": "Base_Drive" }]
    },
    {
      "RuleName": "Button_Feedback_Logic",
      "Type": "Resource_Allocation",
      "MCU": "Atmega",
      "Target_Group": "GPIO_Pool",
      "Slaves": [{ "ComponentID": "1N4007", "Interface": "Feedback_Diode" }]
    }
  ]
}